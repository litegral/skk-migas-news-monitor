# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (server only) — required for /api/cron/sync (bypasses RLS; use only in trusted jobs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron: Vercel Cron sends Authorization: Bearer <CRON_SECRET> when this is set in the project.
# Also accepted: x-cron-secret header (for external pingers).
CRON_SECRET=generate-a-long-random-string

# Optional tuning for cron pipeline (defaults shown)
# CRON_DECODE_ARTICLE_LIMIT=12
# CRON_ANALYZE_BATCH_SIZE=2
# CRON_TIME_BUDGET_MS=110000

# Shared tenant: one Auth user UUID that owns all rss_feeds, topics, articles rows.
# Create this user in Supabase Auth first; use the same UUID in migration 010 (replace placeholder).
SHARED_DATA_USER_ID=your-shared-auth-user-uuid

# RapidAPI - Real-Time News Data (server only)
RAPIDAPI_KEY=your-rapidapi-key

# Groq LLM (server only) — OpenAI-compatible API
# https://console.groq.com/docs/openai
GROQ_API_KEY=your-groq-api-key
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Crawl4AI - full article content extraction (server only)
# Requires a running Crawl4AI Docker container (v0.8+ recommended for proxy escalation).
# Falls back to snippet-only if unavailable.
CRAWL4AI_API_URL=http://localhost:11235
CRAWL4AI_API_TOKEN=your-crawl4ai-api-token
# Optional: direct first, then one proxy per crawl (round-robin across the list).
# When any proxy is set, the app also sends cache_mode=bypass + stream=true on CrawlerRunConfig.
# CRAWL4AI_USE_PROXY=false
#
# Multiple proxies (recommended): multiline or comma-separated.
# Webshare export format per line: host:port:username:password
# Or use full URLs: http://user:pass@host:port
# CRAWL4AI_PROXY_URLS=1.2.3.4:8080:myuser:mypass,1.2.3.5:8080:myuser:mypass
#
# Single proxy (legacy):
# CRAWL4AI_PROXY_URL=http://user:pass@host:port
# CRAWL4AI_PROXY_SERVER=http://host:port
# CRAWL4AI_PROXY_USERNAME=
# CRAWL4AI_PROXY_PASSWORD=
